{
  "name": "led_control",
  // Select between image and build propieties to pull or build the image.
  // "image": "docker.io/espressif/idf-rust:esp32c6_latest",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "CONTAINER_USER": "esp",
      "CONTAINER_GROUP": "esp",
      "ESP_BOARD": "esp32",
    },
  },
  // https://github.com/serialport/serialport-rs/issues/153
  "runArgs": ["--privileged"],
  "mounts": [
    {
      "source": "/dev",
      "target": "/dev",
      "type": "bind",
    },
  ],
}
